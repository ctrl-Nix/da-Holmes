# Holmes OSINT Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────
PROJECT_NAME="Holmes OSINT Platform"
VERSION="1.0.0"

# CORS — restrict to your frontend origin in production
# ALLOWED_ORIGINS='["http://localhost:5173", "https://your-frontend.com"]'

# HTTP Client tuning
REQUEST_TIMEOUT_SECONDS=10.0
MAX_CONCURRENT_REQUESTS=20

# ─────────────────────────────────────────────────────
# INSTAGRAM (Optional — enables reliable 24/7 monitoring)
# How to get:
#   1. Open instagram.com in Chrome, log in
#   2. F12 → Application → Cookies → instagram.com
#   3. Copy the values for: sessionid, ds_user_id, csrftoken
# ─────────────────────────────────────────────────────
INSTAGRAM_SESSION_ID=
INSTAGRAM_DS_USER_ID=
INSTAGRAM_CSRFTOKEN=

# ─────────────────────────────────────────────────────
# TWITTER / X (Optional — bypasses bot blocks)
# How to get:
#   1. Go to developer.twitter.com → Create project → App
#   2. Copy the Bearer Token from "Keys and Tokens"
# Free tier: 500k tweet reads/month
# ─────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=

# ─────────────────────────────────────────────────────
# TIKTOK (Optional — session cookie for profile checks)
# How to get:
#   1. Open tiktok.com in Chrome, log in
#   2. F12 → Application → Cookies → tiktok.com
#   3. Copy the value of: sessionid
# ─────────────────────────────────────────────────────
TIKTOK_SESSION_ID=

# ─────────────────────────────────────────────────────
# LINKEDIN (Optional — bypasses login wall)
# How to get:
#   1. Open linkedin.com in Chrome, log in
#   2. F12 → Application → Cookies → linkedin.com
#   3. Copy the value of: li_at
# ─────────────────────────────────────────────────────
LINKEDIN_LI_AT=

# ─────────────────────────────────────────────────────
# GITHUB (Optional — raises rate limit 60 → 5000 req/hr)
# How to get: github.com → Settings → Developer settings → Personal access tokens
# ─────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────
# OTHER API KEYS (All optional)
# ─────────────────────────────────────────────────────

# Hunter.io — email format inference (25 free/month)
HUNTER_API_KEY=

# Shodan — IoT/port scanning (free account limited)
SHODAN_API_KEY=

# HaveIBeenPwned — breach database ($3.50/month)
HAVEIBEENPWNED_KEY=

# VirusTotal — threat intelligence (4 req/min free)
VIRUSTOTAL_KEY=

# Telegram — push alert notifications (free)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Proxy pool (optional — improves scraping reliability)
# PROXY_POOL_URL=http://username:password@proxy.provider.com:8080
