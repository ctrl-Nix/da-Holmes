# ── OSINT Platform Client Environment Variables ──
# Copy this file to .env inside the client directory and fill in the values.

# The base URL of the FastAPI backend server. 
# In local development, this is typically http://localhost:8000.
# In production, replace this with your hosted Render API URL (e.g. https://da-holmes-api.onrender.com).
VITE_API_URL=http://localhost:8000
